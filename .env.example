# ─────────────────────────────────────
# OZON API
# ─────────────────────────────────────
# Client-ID и API Key из личного кабинета Ozon Seller
# https://seller.ozon.ru/app/settings/api-keys
API_TOKEN=your_ozon_api_key_here
CLIENT_ID=your_ozon_client_id_here

# ─────────────────────────────────────
# GigaChat (облачный AI)
# ─────────────────────────────────────
# Получить: https://developers.sber.ru/studio/workspace
GIGACHAT_CREDENTIALS=your_gigachat_credentials_here

# ─────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────
# Получить у @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ─────────────────────────────────────
# Proxy для Telegram (опционально, если api.telegram.org заблокирован)
# ─────────────────────────────────────
# Форматы:
#   http://login:pass@host:port
#   http://login:pass@[2001:db8::1]:8080   ← IPv6 в квадратных скобках!
#   socks5://login:pass@host:port
#
# Можно указать несколько через запятую — будет fallback на следующий
USE_BOT_PROXY=false
BOT_PROXY_LIST=

# ─────────────────────────────────────
# Администраторы бота (ID Telegram)
# ─────────────────────────────────────
# Можно указать несколько через запятую: 438662734,123456789
ADMIN_IDS=438662734

# ─────────────────────────────────────
# Пути к данным
# ─────────────────────────────────────
DB_PATH=./data/reviews.db
REVIEWS_CONFIG_PATH=./data/reviews_config.json
REVIEWS_COUNTER_PATH=./data/rewiews_counter.json
